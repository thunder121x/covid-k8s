# Copy this file to .env and fill in real values.
# .env is gitignored — this file is safe to commit.

# ── Secrets (REQUIRED) ───────────────────────────────────────────────────────
DB_PASSWORD=

# Discord webhook ID and token (from Webhook URL: .../webhooks/<ID>/<TOKEN>)
DISCORD_ID=
DISCORD_TOKEN=

# ── Database (optional, defaults work inside Kubernetes) ─────────────────────
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=aqi
DB_USER=postgres

# ── Redis (optional, defaults work inside Kubernetes) ────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── App tuning (optional) ─────────────────────────────────────────────────────
CACHE_TTL=30
